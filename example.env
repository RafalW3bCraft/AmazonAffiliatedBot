# OPTIONAL: OpenAI API key for AI-generated deal text.
OPENAI_API_KEY=
# REQUIRED: Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=
# REQUIRED for posting: Telegram channel username, e.g. @my_channel.
TELEGRAM_CHANNEL=
# OPTIONAL: PostgreSQL connection URL. If empty, app falls back to in-memory DB.
DATABASE_URL=
# OPTIONAL: Individual PostgreSQL connection fields.
PGDATABASE=
PGHOST=
PGPASSWORD=
PGUSER=
# REQUIRED: Amazon Associates affiliate tag.
AMAZON_AFFILIATE_ID=one4allmarket-21
